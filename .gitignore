# ==========================================
# Dependências e Ambientes (Crucial)
# ==========================================
node_modules/
/node_modules
*/node_modules/
apps/backend/node_modules/
apps/frontend/node_modules/
packages/types/node_modules/

# Arquivos de Variáveis de Ambiente (Segurança Máxima)
.env
.env.local
.env.*
!.env.example

# ==========================================
# Artefatos de Build e Compilação (TypeScript/Vite)
# ==========================================
# Ignora as pastas onde o TSC e o Vite cospem o código compilado
dist/
build/
/apps/backend/dist/
/apps/frontend/dist/
/packages/types/dist/
out/
.output/

# Cache de compilação do TypeScript e do Vite
*.tsbuildinfo
.vite/
.turbo/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ==========================================
# Logs e Diagnósticos
# ==========================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# IDEs, Sistema Operacional e Editores
# ==========================================
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db
# Lockfiles alternativos (evita conflito se alguém usar yarn/pnpm)
yarn.lock
pnpm-lock.yaml

# Coverage de testes
coverage/

# Uploads e arquivos temporários
*.local