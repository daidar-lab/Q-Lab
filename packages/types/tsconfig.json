{
    "compilerOptions": {
        "composite": true,
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": true,
        "strict": true,
        "skipLibCheck": true
    },
    "include": [
        "**/*.ts"
    ], // Lê os seus arquivos .ts da raiz da pasta
    "exclude": [
        "dist",
        "node_modules"
    ]
}